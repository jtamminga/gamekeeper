{
  "compilerOptions": {
    "target": "ESNext",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "module": "ESNext",
    "rootDir": "./src",
    "moduleResolution": "bundler",
    "paths": {
      "@domains": ["./src/domains"],
      "@domains/gameplay": ["./src/domains/gameplay"],
      "@domains/insights": ["./src/domains/insights"],
      "@repos": ["./src/repositories"],
      "@core": ["./src/core"],
      "@services": ["./src/services"]
    },
    "declaration": true,
    "sourceMap": true,
    "outDir": "./dist",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "tsc-alias": {
    "resolveFullPaths": true,
    "verbose": false
  },
  "include": ["src/**/*"],
}
